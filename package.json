{
  "name": "ai-website-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "overrides": {
    "jose": "4.15.9"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
